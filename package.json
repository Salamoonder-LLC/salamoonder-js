{
  "name": "salamoonder-js",
  "version": "1.0.3",
  "description": "A straightforward JS wrapper for Salamoonder's API, designed for easy integration and usage.",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./client": "./client.js",
    "./tasks": "./tasks.js",
    "./utils/akamai": "./utils/akamai.js",
    "./utils/datadome": "./utils/datadome.js",
    "./utils/kasada": "./utils/kasada.js"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "tlsclientwrapper": "*"
  },
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "jest": "^29.7.0"
  },
  "keywords": [
    "salamoonder",
    "api",
    "captcha",
    "kasada",
    "akamai",
    "datadome",
    "incapsula",
    "bot-detection",
    "akamai-sensor-generator",
    "akamai-solver",
    "akamai-bypass",
    "incapsula-bypass",
    "incapsula-solver",
    "kasada-bypass",
    "kasada-solver",
    "datadome-solver",
    "datadome-bypass"
  ],
  "author": "Salamoonder LLC",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Salamoonder-LLC/salamoonder-js"
  }
}
